# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# secrets keys
.secrets/*

# keep the folder but ignore the content
!.secrets/.gitkeep

# logs and parquet
*.log
*.parquet

# misc files folders
misc

# Data output folder
data_output/*
Log_files/*
scrapy_logs/*

# keep the folder but ignore the content
!data_output/.gitkeep
!Log_files/.gitkeep
!scrapy_logs/.gitkeep

# DUCKDB
*.duckdb